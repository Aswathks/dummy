import re
from datetime import datetime


def parse_receipt_text(text, file_name):
    lines = text.split("\n")
    lines = [line.strip() for line in lines if line.strip()]

    vendor = lines[0] if lines else "Unknown"

    amount = None
    date = None

    # find amount
    amount_patterns = [
        r"total[:\s₹$]*([\d,]+\.?\d*)",
        r"amount[:\s₹$]*([\d,]+\.?\d*)",
        r"₹\s*([\d,]+\.?\d*)",
        r"\$\s*([\d,]+\.?\d*)"
    ]

    for pattern in amount_patterns:
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            amount = match.group(1).replace(",", "")
            break

    # find date
    date_patterns = [
        r"\d{2}/\d{2}/\d{4}",
        r"\d{2}-\d{2}-\d{4}",
        r"\d{4}-\d{2}-\d{2}"
    ]

    for pattern in date_patterns:
        match = re.search(pattern, text)
        if match:
            date = match.group(0)
            break

    if amount is None:
        amount = 0

    return {
        "file_name": file_name,
        "vendor": vendor,
        "amount": float(amount),
        "date": date,
        "raw_text": text
    }
