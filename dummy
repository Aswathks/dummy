import sqlite3
from pathlib import Path
import chromadb
from sentence_transformers import SentenceTransformer

BASE_DIR = Path(__file__).resolve().parent.parent

DB_PATH = BASE_DIR / "database" / "expense_tracker.db"
CHROMA_PATH = BASE_DIR / "vector_store" / "chroma_db"

# Load embedding model
model = SentenceTransformer("all-MiniLM-L6-v2")

# Create Chroma client
client = chromadb.PersistentClient(path=str(CHROMA_PATH))

# Create / get collection
collection = client.get_or_create_collection(
    name="expense_transactions"
)


def create_embedding_text(row):
    """
    Convert transaction row into meaningful text for embeddings
    """

    text = f"""
    Vendor: {row['vendor']}
    Date: {row['date']}
    Amount: {row['total_amount']}
    Payment Method: {row['payment_method']}
    Category: {row['category']}
    """

    return text.strip()


def generate_embeddings():
    """
    Read SQLite transactions
    → Create embeddings
    → Store in ChromaDB
    """

    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()

    cursor.execute("""
        SELECT id, vendor, date, total_amount,
               payment_method, category
        FROM transactions
    """)

    rows = cursor.fetchall()
    conn.close()

    if not rows:
        return {
            "status": "No transactions found"
        }

    inserted_count = 0

    for row in rows:
        row_dict = dict(row)

        document_text = create_embedding_text(row_dict)

        embedding = model.encode(document_text).tolist()

        doc_id = str(row_dict["id"])

        # store in ChromaDB
        collection.upsert(
            ids=[doc_id],
            documents=[document_text],
            embeddings=[embedding],
            metadatas=[{
                "vendor": row_dict["vendor"],
                "category": row_dict["category"],
                "amount": row_dict["total_amount"]
            }]
        )

        inserted_count += 1

    return {
        "status": "success",
        "total_embeddings_created": inserted_count
    }


def search_similar_transactions(query, top_k=5):
    """
    Search similar transactions using semantic search
    """

    query_embedding = model.encode(query).tolist()

    results = collection.query(
        query_embeddings=[query_embedding],
        n_results=top_k
    )

    return results