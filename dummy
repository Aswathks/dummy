import sqlite3
from pathlib import Path

from embedding_service import search_similar_transactions

BASE_DIR = Path(__file__).resolve().parent.parent
DB_PATH = BASE_DIR / "database" / "expense_tracker.db"


def get_sql_answer(question):
    question = question.lower()

    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()

    answer = None

    if "total" in question or "overall" in question or "spent" in question:
        cursor.execute("SELECT SUM(total_amount) FROM transactions")
        result = cursor.fetchone()[0]
        answer = f"Your total spending is {result:.2f}"

    elif "food" in question:
        cursor.execute("""
            SELECT SUM(total_amount)
            FROM transactions
            WHERE category = 'Food'
        """)
        result = cursor.fetchone()[0]
        answer = f"Your total food spending is {result:.2f}"

    elif "highest" in question or "biggest" in question or "top expense" in question:
        cursor.execute("""
            SELECT vendor, total_amount, category
            FROM transactions
            ORDER BY total_amount DESC
            LIMIT 1
        """)
        result = cursor.fetchone()

        if result:
            answer = f"Your highest expense is {result[0]} with amount {result[1]:.2f} under {result[2]} category."

    elif "credit card" in question:
        cursor.execute("""
            SELECT SUM(total_amount)
            FROM transactions
            WHERE payment_method = 'Credit Card'
        """)
        result = cursor.fetchone()[0]
        answer = f"Your credit card spending is {result:.2f}"

    conn.close()
    return answer


def get_rag_answer(question):
    results = search_similar_transactions(question, top_k=5)

    documents = results.get("documents", [[]])[0]

    if not documents:
        return "I could not find related expense records."

    context = "\n\n".join(documents)

    answer = f"""
Based on your uploaded expense records:

{context}

Answer:
{question}
"""

    return answer.strip()


def answer_question(question):
    sql_answer = get_sql_answer(question)

    if sql_answer:
        return {
            "answer_type": "SQL",
            "answer": sql_answer
        }

    rag_answer = get_rag_answer(question)

    return {
        "answer_type": "RAG",
        "answer": rag_answer
    }