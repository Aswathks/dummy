import re


def clean_amount(value):
    if not value:
        return 0

    value = value.replace(",", "")
    value = value.replace("$", "")
    value = value.replace("₹", "")
    value = value.replace("€", "")
    value = value.replace("CHF", "")
    value = value.strip()

    try:
        return float(value)
    except:
        return 0


def parse_receipt_text(text, file_name):
    lines = text.split("\n")
    lines = [line.strip() for line in lines if line.strip()]

    # Vendor
    vendor = "Unknown"
    for line in lines:
        if not any(word in line.upper() for word in ["RECEIPT", "DATE", "TOTAL", "SUBTOTAL", "TAX", "TIP"]):
            vendor = line
            break

    # Date
    date = "Not Found"

    date_patterns = [
        r"[A-Za-z]+\s+\d{1,2}(st|nd|rd|th)?,\s*\d{4}",
        r"\d{1,2}[/-]\d{1,2}[/-]\d{4}",
        r"\d{4}[/-]\d{1,2}[/-]\d{1,2}",
        r"\d{1,2}\.\d{1,2}\.\d{4}"
    ]

    for pattern in date_patterns:
        match = re.search(pattern, text)
        if match:
            date = match.group(0)
            break

    # Total amount - prefer final TOTAL, not SUBTOTAL
    total_amount = 0

    total_matches = re.findall(
        r"(?<!SUB)TOTAL\s*[:\-]?\s*(?:\$|₹|€|CHF)?\s*([\d,]+\.?\d*)",
        text,
        re.IGNORECASE
    )

    if total_matches:
        total_amount = clean_amount(total_matches[-1])
    else:
        # fallback: take last money value
        money_matches = re.findall(
            r"(?:\$|₹|€|CHF)\s*([\d,]+\.?\d*)",
            text,
            re.IGNORECASE
        )
        if money_matches:
            total_amount = clean_amount(money_matches[-1])

    # Payment method
    payment_method = "Unknown"
    upper_text = text.upper()

    if "CREDIT CARD" in upper_text:
        payment_method = "Credit Card"
    elif "DEBIT CARD" in upper_text:
        payment_method = "Debit Card"
    elif "VISA" in upper_text:
        payment_method = "Visa Card"
    elif "MASTERCARD" in upper_text:
        payment_method = "Mastercard"
    elif "CASH" in upper_text:
        payment_method = "Cash"
    elif "UPI" in upper_text:
        payment_method = "UPI"

    return {
        "file_name": file_name,
        "vendor": vendor,
        "date": date,
        "total_amount": total_amount,
        "payment_method": payment_method,
        "raw_text": text
    }
