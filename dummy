import sqlite3
import pandas as pd
import json
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent
DB_PATH = BASE_DIR / "database" / "expense_tracker.db"
REPORTS_FOLDER = BASE_DIR / "exports" / "reports"

REPORTS_FOLDER.mkdir(parents=True, exist_ok=True)


def generate_reports():
    conn = sqlite3.connect(DB_PATH)

    df = pd.read_sql_query("""
        SELECT id, file_name, vendor, date, total_amount, payment_method, category
        FROM transactions
    """, conn)

    conn.close()

    if df.empty:
        return {"message": "No transactions found"}

    # Category summary
    category_summary = df.groupby("category")["total_amount"].sum().reset_index()
    category_summary.to_csv(REPORTS_FOLDER / "category_summary.csv", index=False)

    # Top expenses
    top_expenses = df.sort_values(by="total_amount", ascending=False).head(10)
    top_expenses.to_csv(REPORTS_FOLDER / "top_expenses.csv", index=False)

    # Monthly summary
    monthly_summary = df.groupby("date")["total_amount"].sum().reset_index()
    monthly_summary.to_csv(REPORTS_FOLDER / "monthly_summary.csv", index=False)

    # JSON summary
    expense_summary = {
        "total_transactions": int(len(df)),
        "total_spent": float(df["total_amount"].sum()),
        "top_category": category_summary.sort_values(by="total_amount", ascending=False).iloc[0]["category"],
        "top_vendor": top_expenses.iloc[0]["vendor"],
        "highest_expense": float(top_expenses.iloc[0]["total_amount"])
    }

    with open(REPORTS_FOLDER / "expense_summary.json", "w", encoding="utf-8") as f:
        json.dump(expense_summary, f, indent=4)

    return expense_summary