def categorize_transaction(text, vendor=""):
    full_text = (text + " " + vendor).lower()

    if any(word in full_text for word in ["coffee", "restaurant", "diner", "burger", "pizza", "hotel", "food", "momos", "curry", "soda"]):
        return "Food"

    elif any(word in full_text for word in ["uber", "ola", "taxi", "fuel", "petrol", "diesel", "metro", "bus", "train"]):
        return "Transport"

    elif any(word in full_text for word in ["apple", "amazon", "flipkart", "store", "electronics", "shopping"]):
        return "Shopping"

    elif any(word in full_text for word in ["electricity", "water bill", "recharge", "internet", "phone bill", "bill payment"]):
        return "Bills"

    elif any(word in full_text for word in ["hospital", "medical", "pharmacy", "clinic", "drugs"]):
        return "Health"

    elif any(word in full_text for word in ["netflix", "movie", "cinema", "spotify", "game"]):
        return "Entertainment"

    else:
        return "Others"