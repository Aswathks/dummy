def categorize_transaction(text):
    text = text.lower()

    if any(word in text for word in ["zomato", "swiggy", "restaurant", "food", "hotel"]):
        return "Food"

    elif any(word in text for word in ["uber", "ola", "fuel", "petrol", "diesel", "metro"]):
        return "Transport"

    elif any(word in text for word in ["amazon", "flipkart", "shopping", "store"]):
        return "Shopping"

    elif any(word in text for word in ["electricity", "water", "bill", "recharge"]):
        return "Bills"

    elif any(word in text for word in ["hospital", "medical", "pharmacy"]):
        return "Health"

    else:
        return "Others"
