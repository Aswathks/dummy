from pathlib import Path
import json
import cv2
from paddleocr import PaddleOCR

BASE_DIR = Path(__file__).resolve().parent.parent

RECEIPT_PATH = BASE_DIR / "data" / "raw" / "receipts"
BANK_PATH = BASE_DIR / "data" / "raw" / "bank_statements"

RECEIPT_OUT_TXT = BASE_DIR / "data" / "extracted_text" / "receipts"
BANK_OUT_TXT = BASE_DIR / "data" / "extracted_text" / "bank_statements"

RECEIPT_OUT_JSON = BASE_DIR / "data" / "parsed_json" / "receipts"
BANK_OUT_JSON = BASE_DIR / "data" / "parsed_json" / "bank_statements"

VALID_EXTENSIONS = {".png", ".jpg", ".jpeg", ".webp"}

for folder in [RECEIPT_OUT_TXT, BANK_OUT_TXT, RECEIPT_OUT_JSON, BANK_OUT_JSON]:
    folder.mkdir(parents=True, exist_ok=True)

ocr = PaddleOCR(lang="en")


def extract_text_from_result(result):
    lines = []

    if not result:
        return lines

    # New PaddleOCR versions may return dict-style result
    if isinstance(result, list):
        for page in result:
            if isinstance(page, dict):
                texts = page.get("rec_texts", [])
                scores = page.get("rec_scores", [])
                boxes = page.get("rec_boxes", [])

                for i, text in enumerate(texts):
                    lines.append({
                        "text": str(text),
                        "score": float(scores[i]) if i < len(scores) else 0.0,
                        "box": boxes[i].tolist() if i < len(boxes) and hasattr(boxes[i], "tolist") else None
                    })

            elif isinstance(page, list):
                for item in page:
                    try:
                        text = item[1][0]
                        score = float(item[1][1])
                        box = item[0]
                        lines.append({
                            "text": str(text),
                            "score": score,
                            "box": box
                        })
                    except Exception:
                        pass

    return lines


def preprocess_image(image_path):
    image = cv2.imread(str(image_path))

    if image is None:
        print(f"[ERROR] Cannot read image: {image_path}")
        return None

    h, w = image.shape[:2]

    if w < 1400:
        scale = 1400 / w
        image = cv2.resize(image, None, fx=scale, fy=scale, interpolation=cv2.INTER_CUBIC)

    return image


def run_ocr(image_path):
    image = preprocess_image(image_path)

    if image is None:
        return [], ""

    result = ocr.ocr(image)
    lines = extract_text_from_result(result)

    text = "\n".join([line["text"] for line in lines if line["text"].strip()])

    return lines, text


def process_folder(input_dir, txt_dir, json_dir):
    print(f"\nChecking: {input_dir}")

    files = sorted([f for f in input_dir.iterdir() if f.suffix.lower() in VALID_EXTENSIONS])
    print(f"Found {len(files)} files")

    for file_path in files:
        print(f"\nProcessing: {file_path.name}")

        lines, text = run_ocr(file_path)

        txt_path = txt_dir / f"{file_path.stem}.txt"
        json_path = json_dir / f"{file_path.stem}.json"

        with open(txt_path, "w", encoding="utf-8") as f:
            f.write(text)

        with open(json_path, "w", encoding="utf-8") as f:
            json.dump({
                "file_name": file_path.name,
                "raw_text": text,
                "ocr_lines": lines
            }, f, indent=2, ensure_ascii=False)

        print(f"Extracted lines: {len(lines)}")
        print(f"Saved TXT: {txt_path}")

        if len(text.strip()) == 0:
            print("WARNING: No text extracted")


if __name__ == "__main__":
