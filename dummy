import sqlite3
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent.parent
DB_PATH = BASE_DIR / "database" / "expense_tracker.db"


def create_tables():
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()

    cursor.execute("""
        CREATE TABLE IF NOT EXISTS transactions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            file_name TEXT,
            vendor TEXT,
            date TEXT,
            total_amount REAL,
            payment_method TEXT,
            category TEXT,
            raw_text TEXT
        )
    """)

    conn.commit()
    conn.close()


def insert_transaction(data):
    create_tables()

    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()

    cursor.execute("""
        INSERT INTO transactions
        (file_name, vendor, date, total_amount, payment_method, category, raw_text)
        VALUES (?, ?, ?, ?, ?, ?, ?)
    """, (
        data["file_name"],
        data["vendor"],
        data["date"],
        data["total_amount"],
        data["payment_method"],
        data["category"],
        data["raw_text"]
    ))

    conn.commit()
    conn.close()


def get_all_transactions():
    create_tables()

    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()

    cursor.execute("""
        SELECT id, file_name, vendor, date, total_amount, payment_method, category
        FROM transactions
    """)

    rows = cursor.fetchall()
    conn.close()

    return rows