import re


def parse_receipt_text(text, file_name):
    lines = text.split("\n")
    lines = [line.strip() for line in lines if line.strip()]

    # Vendor name usually comes in first line
    vendor = lines[0] if lines else "Unknown"

    # Extract total amount
    total_amount = 0

    total_patterns = [
        r"TOTAL[:\s\$₹€]*([\d,]+\.?\d*)",
        r"Total[:\s\$₹€]*([\d,]+\.?\d*)",
        r"total[:\s\$₹€]*([\d,]+\.?\d*)",
        r"TOTAL\s*\$?\s*([\d,]+\.?\d*)"
    ]

    for pattern in total_patterns:
        match = re.search(pattern, text)
        if match:
            total_amount = float(match.group(1).replace(",", ""))
            break

    # Extract date
    date = "Not Found"

    date_patterns = [
        r"[A-Za-z]+\s\d{1,2}(st|nd|rd|th)?,\s\d{4}",
        r"\d{2}/\d{2}/\d{4}",
        r"\d{2}-\d{2}-\d{4}",
        r"\d{4}-\d{2}-\d{2}"
    ]

    for pattern in date_patterns:
        match = re.search(pattern, text)
        if match:
            date = match.group(0)
            break

    # Extract payment method
    payment_method = "Unknown"

    upper_text = text.upper()

    if "CREDIT CARD" in upper_text:
        payment_method = "Credit Card"
    elif "DEBIT CARD" in upper_text:
        payment_method = "Debit Card"
    elif "CASH" in upper_text:
        payment_method = "Cash"
    elif "UPI" in upper_text:
        payment_method = "UPI"
    elif "VISA" in upper_text:
        payment_method = "Visa Card"

    return {
        "file_name": file_name,
        "vendor": vendor,
        "date": date,
        "total_amount": total_amount,
        "payment_method": payment_method,
        "raw_text": text
    }
