import pandas as pd
from pathlib import Path
import re

BASE_DIR = Path(__file__).resolve().parent.parent

RECEIPT_JSON = BASE_DIR / "data" / "parsed_json" / "receipts"
BANK_JSON = BASE_DIR / "data" / "parsed_json" / "bank_statements"

OUTPUT_CSV = BASE_DIR / "data" / "processed" / "transactions.csv"


# ---------- HELPERS ----------

def extract_amount(text):
    matches = re.findall(r"\d+[.,]?\d*", text)
    if matches:
        try:
            return float(matches[-1].replace(",", ""))
        except:
            return None
    return None


def extract_date(text):
    match = re.search(r"\d{1,2}[-/]\d{1,2}[-/]\d{2,4}", text)
    return match.group(0) if match else None


# ---------- RECEIPT PARSER ----------

def parse_receipts():
    records = []

    for file in RECEIPT_JSON.glob("*.json"):
        with open(file, "r", encoding="utf-8") as f:
            data = json.load(f)

        lines = data.get("ocr_lines", [])

        merchant = None
        total = None
        date = None

        for line in lines:
            text = line["text"].lower()

            if not merchant:
                merchant = line["text"]

            if "total" in text or "amount" in text:
                total = extract_amount(line["text"])

            if not date:
                date = extract_date(line["text"])

        if total:
            records.append({
                "date": date,
                "merchant": merchant,
                "description": "receipt purchase",
                "amount": total,
                "transaction_type": "debit",
                "source": "receipt"
            })

    return records


# ---------- BANK PARSER ----------

def parse_bank():
    records = []

    for file in BANK_JSON.glob("*.json"):
        with open(file, "r", encoding="utf-8") as f:
            data = json.load(f)

        lines = data.get("ocr_lines", [])

        for line in lines:
            text = line["text"]

            # Try detecting rows with numbers (transactions)
            if any(char.isdigit() for char in text):

                date = extract_date(text)
                amount = extract_amount(text)

                if amount:
                    records.append({
                        "date": date,
                        "merchant": "bank_transaction",
                        "description": text,
                        "amount": amount,
                        "transaction_type": "unknown",
                        "source": "bank"
                    })

    return records


# ---------- MAIN ----------

def main():
    receipt_data = parse_receipts()
    bank_data = parse_bank()

    all_data = receipt_data + bank_data

    df = pd.DataFrame(all_data)

    df.insert(0, "transaction_id", range(1, len(df) + 1))

    OUTPUT_CSV.parent.mkdir(parents=True, exist_ok=True)
    df.to_csv(OUTPUT_CSV, index=False)

    print(f"Saved transactions: {len(df)}")
    print(f"File: {OUTPUT_CSV}")


if __name__ == "__main__":
    main()

